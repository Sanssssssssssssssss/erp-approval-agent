{
  "cases": [
    {
      "case_id": "recovery_timeout_retry_success",
      "suite": "integration",
      "runner": "integration_lifecycle",
      "scenario": "mcp_web_recovery_timeout",
      "message": "Use Web MCP only, fetch {{web_base_url}}/recovery/retry, and tell me the result.",
      "session_id": "integration-recovery-timeout",
      "tags": ["smoke", "recovery", "mcp", "web"],
      "difficulty": "smoke",
      "setup": {
        "recovery_sequence": [
          {
            "name": "mcp_web_fetch_url",
            "results": [
              {
                "status": "failed",
                "error_type": "timeout",
                "error_message": "scripted timeout"
              },
              {
                "status": "success",
                "payload": {
                  "text": "recovered web result"
                }
              }
            ]
          }
        ]
      },
      "tool_calls": [
        {
          "name": "mcp_web_fetch_url",
          "args": {
            "url": "{{web_base_url}}/recovery/retry"
          }
        }
      ],
      "expect": {
        "route_intent": "web_lookup",
        "tool": true,
        "failure": false,
        "answer_fragment": "recovered web result",
        "recovery_action": "retry_once"
      }
    },
