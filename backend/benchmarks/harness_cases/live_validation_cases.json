      "expect_route": "workspace_file_ops",
      "expect_tool": true,
      "expect_capability": true,
      "expect_capability_governance": true,
      "expect_resume": true,
      "expect_final_contains": ["7"],
      "setup": {
        "hitl_edited_input": {
          "code": "print(3 + 4)"
        }
      },
      "tool_calls": [
        {
          "name": "python_repl",
          "args": {
            "code": "print(2 + 2)"
          }
        }
      ],
      "tags": ["smoke", "hitl", "edit"]
    },
    {
      "case_id": "live_hitl_python_repl_reject",
