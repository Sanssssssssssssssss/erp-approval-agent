        {
          "name": "python_repl",
          "args": {
            "code": "print(2 + 2)"
          }
        }
      ],
      "tags": ["smoke", "hitl"]
    },
    {
      "case_id": "live_hitl_python_repl_edit",
      "scenario": "hitl_python_repl_edit",
