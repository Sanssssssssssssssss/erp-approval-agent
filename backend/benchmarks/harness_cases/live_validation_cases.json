      "tool_calls": [
        {
          "name": "python_repl",
          "args": {
            "code": "print(2 + 2)"
          }
        }
      ],
      "tags": ["smoke", "hitl", "reject"]
    },
    {
      "case_id": "live_recovery_timeout_retry",
      "scenario": "mcp_web_recovery_timeout",
      "message": "Use Web MCP only, fetch {{web_base_url}}/live/recovery/retry, and answer with the page text.",
      "expect_route": "web_lookup",
      "expect_tool": true,
      "expect_capability": true,
      "expect_capability_governance": true,
      "expect_recovery_action": "retry_once",
      "expect_final_contains": ["live recovered web result"],
      "model_answer": "live recovered web result",
      "setup": {
        "recovery_sequence": [
          {
            "name": "mcp_web_fetch_url",
            "results": [
              {
                "status": "failed",
                "error_type": "timeout",
                "error_message": "live scripted timeout"
              },
              {
                "status": "success",
                "payload": {
                  "text": "live recovered web result"
                }
              }
            ]
          }
        ]
      },
      "tool_calls": [
        {
          "name": "mcp_web_fetch_url",
          "args": {
            "url": "{{web_base_url}}/live/recovery/retry"
          }
        }
      ],
      "tags": ["smoke", "recovery", "web"]
    },
    {
      "case_id": "live_recovery_capability_unavailable_fallback",
