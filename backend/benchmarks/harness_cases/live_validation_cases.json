        {
          "name": "mcp_web_fetch_url",
          "args": {
            "url": "{{web_base_url}}/live/recovery/unavailable"
          }
        }
      ],
      "tags": ["smoke", "recovery", "web"]
    },
    {
      "case_id": "live_recovery_escalate_to_hitl_reject",
