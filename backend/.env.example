# LLM defaults
# Supported providers: zhipu, bailian, deepseek, openai
LLM_PROVIDER=zhipu
LLM_MODEL=glm-5
LLM_API_KEY=
LLM_BASE_URL=
LLM_THINKING_TYPE=

# Zhipu / BigModel
ZHIPU_API_KEY=your_key
ZHIPUAI_API_KEY=your_key
ZHIPU_BASE_URL=https://open.bigmodel.cn/api/paas/v4/
ZHIPU_MODEL=glm-5

# Bailian / DashScope
BAILIAN_API_KEY=your_key
DASHSCOPE_API_KEY=your_key
BAILIAN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
BAILIAN_MODEL=qwen3.5-plus

# DeepSeek
DEEPSEEK_API_KEY=your_key
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# OpenAI-compatible embeddings defaults
# Supported providers: zhipu, bailian, openai, local
EMBEDDING_PROVIDER=zhipu
EMBEDDING_MODEL=embedding-3
EMBEDDING_API_KEY=
EMBEDDING_BASE_URL=

# Bailian / DashScope embeddings example
# EMBEDDING_PROVIDER=bailian
# EMBEDDING_MODEL=text-embedding-v4
# EMBEDDING_API_KEY=your_dashscope_key
# EMBEDDING_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# OpenAI embeddings
OPENAI_API_KEY=your_key
OPENAI_BASE_URL=https://api.openai.com/v1

# Moonshot / Kimi example
# LLM_PROVIDER=openai
# LLM_MODEL=kimi-k2.5
# LLM_BASE_URL=https://api.moonshot.cn/v1
# LLM_THINKING_TYPE=disabled

# Optional benchmark judge model (OpenAI-compatible)
JUDGE_BASE_URL=
JUDGE_API_KEY=
JUDGE_MODEL=
JUDGE_TIMEOUT_SECONDS=120

# Optional lightweight router override
ROUTER_MODEL=
ROUTER_API_KEY=
ROUTER_BASE_URL=

# Optional evidence-first case stage model.
# When enabled, /api/erp-approval/cases/turn asks the configured LLM to propose a bounded CasePatch.
# The model cannot write case_state directly; CasePatchValidator still enforces source_id/claim/action boundaries.
ERP_CASE_STAGE_MODEL_ENABLED=false

# ERP approval connector interface (Phase 11)
# Default is mock, disabled, and local-only. Do not store production ERP credentials in this file.
# SAP/Dynamics/Oracle/custom profiles are read-only skeleton metadata, not completed live integrations.
ERP_CONNECTOR_PROVIDER=mock
ERP_CONNECTOR_ENABLED=false
ERP_CONNECTOR_ALLOW_NETWORK=false
ERP_CONNECTOR_BASE_URL=
ERP_CONNECTOR_TENANT_ID=
ERP_CONNECTOR_COMPANY_ID=
ERP_CONNECTOR_TIMEOUT_SECONDS=10
ERP_CONNECTOR_AUTH_TYPE=none
ERP_CONNECTOR_AUTH_ENV_VAR=
ERP_CONNECTOR_EXPLICIT_READ_ONLY_OPT_IN=false
ERP_CONNECTOR_USE_AS_DEFAULT=false

# Tavily web search
TAVILY_API_KEY=your_key
TAVILY_PROJECT=

# LangSmith Studio / tracing
LANGSMITH_API_KEY=
LANGSMITH_TRACING=true
# Optional: keep Studio runs in a dedicated LangSmith project so they don't mix with local tests or scripts.
RAGCLAW_STUDIO_LANGSMITH_PROJECT=Ragclaw Studio
# Optional generic project for non-Studio LangSmith traces.
# LANGSMITH_PROJECT=Ragclaw Local
# Optional: enable OTel spans locally.
# RAGCLAW_OTEL_ENABLED=1
# RAGCLAW_OTEL_CONSOLE_EXPORTER=1
# OTEL_EXPORTER_OTLP_ENDPOINT=http://127.0.0.1:4318/v1/traces
# OTEL_ENVIRONMENT=local
# Disable LangSmith export during local test runs unless explicitly re-enabled.
# RAGCLAW_TEST_ENABLE_LANGSMITH=0
# Optional compatibility alias if you already use the legacy variable name:
# LANGCHAIN_API_KEY=
